{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Goonware",
  "version": "0.0.1",
  "identifier": "dev.raeedz.goonware",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Goonware",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "theme": "Dark",
        "fullscreen": false,
        "resizable": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: asset: http://asset.localhost http://127.0.0.1:*; media-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:* https://generativelanguage.googleapis.com https://github.com https://*.githubusercontent.com https://api.github.com",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "externalBin": ["binaries/rg"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "category": "public.app-category.developer-tools",
    "shortDescription": "Workspace for running CLI coding agents.",
    "longDescription": "Goonware is a confident dark instrument for spawning, organizing, and orchestrating CLI coding agents like Claude Code and Codex. macOS only."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Raeedzz/Goonware/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxOEFCNTAxNUQ0OEY0RjcKUldUMzlFaGRBYldLY1RXWWV5a1ppcG94QlVxd2xZMjZ3eEFTbTMzc3g3eFhuUFJjQitqdjhZbXUK"
    }
  }
}
