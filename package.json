{
  "name": "goonware",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "A confident dark instrument for running CLI coding agents.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "bun run download-rg && tauri dev",
    "tauri:build": "bun run download-rg && tauri build",
    "download-rg": "bash scripts/download-rg.sh",
    "typecheck": "tsc -b",
    "test": "bun test src",
    "test:rs": "cd src-tauri && cargo test --lib",
    "test:all": "bun run test && bun run test:rs && bun run typecheck"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
